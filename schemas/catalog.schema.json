{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SiMa NEAT Apps Catalog",
  "type": "object",
  "required": [
    "schema_version",
    "examples"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "examples": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "language",
          "category",
          "source_path",
          "status"
        ],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "language": {
            "type": "string",
            "enum": ["cpp", "python"]
          },
          "category": { "type": "string" },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          },
          "status": {
            "type": "string",
            "enum": ["stable", "experimental", "planned", "blocked"]
          },
          "source_path": { "type": "string" },
          "binary_name": { "type": "string" },
          "notes": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
