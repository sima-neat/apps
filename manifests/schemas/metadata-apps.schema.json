{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SiMa NEAT Apps Metadata (Early Release)",
  "type": "object",
  "required": [
    "schema_version",
    "artifact_name",
    "apps_version",
    "tested_with_core"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "artifact_name": {
      "type": "string",
      "const": "sima-neat-apps"
    },
    "apps_version": {
      "type": "string"
    },
    "tested_with_core": {
      "type": "object",
      "required": ["metadata_url"],
      "properties": {
        "metadata_url": { "type": "string" },
        "branch": { "type": "string" },
        "tag": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
