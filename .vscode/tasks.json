{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Apps: Test Unit C++",
      "type": "shell",
      "command": "bash",
      "args": [
        "tests/scripts/testing/run_vscode_test_task.sh",
        "--unit",
        "--cpp"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "presentation": {
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "showReuseMessage": false,
        "clear": false,
        "close": false
      },
      "problemMatcher": []
